# ── LLM APIs ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here             # Todos los agentes (desarrollo)
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # Agentes 3/4/5 (producción, opcional)
OPENAI_API_KEY=your_openai_api_key_here         # GPT-4o fallback (opcional)

# ── Observability ──────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-incident-response

# ── RAG / Vector Store ─────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
COHERE_API_KEY=your_cohere_api_key_here         # reranker (opcional)

# ── Tool integrations (mock-friendly: leave empty to use mock) ─────────────────
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
GITHUB_TOKEN=your_github_token_here
GITHUB_ORG=your_org
K8S_KUBECONFIG_PATH=~/.kube/config
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_HITL_CHANNEL=#incident-approvals

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
